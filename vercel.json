{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "protocol",
          "value": "http"
        }
      ],
      "destination": "https://vendet.online/:path*",
      "permanent": 308
    }
  ]
}
